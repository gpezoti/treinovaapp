+function paymentEffectiveStatus(p) {
+  const raw = String(p.status || "pending").toLowerCase();
+  if (raw === "paid" || raw === "cancelled" || raw === "canceled") return raw === "canceled" ? "cancelled" : raw;
+  const due = String(p.due_date || "");
+  const today = new Date().toISOString().slice(0, 10);
+  if (raw === "overdue" || (due && due < today)) return "overdue";
+  return raw === "pending" ? "upcoming" : "pending";
+}
+
+function paymentStatusBadge(status) {
+  const labels = {
+    paid: ["Pago", "pill-approved"],
+    overdue: ["Em atraso", "pill-red"],
+    cancelled: ["Cancelado", "pill-off"],
+    upcoming: ["A vencer", "pill-pending"],
+    pending: ["Pendente", "pill-pending"]
+  };
+  const [label, cls] = labels[status] || labels.pending;
+  return `<span class="today-pill ${cls}">${label}</span>`;
+}
+
+function paymentTitle(p) {
+  return escape(p.reference || p.title || p.description || "Mensalidade");
+}
+
+function paymentMethodLabel(method) {
+  const m = String(method || "").toLowerCase();
+  if (!m) return "Método não informado";
+  if (m === "pix") return "PIX";
+  if (m === "boleto") return "Boleto";
+  if (m === "credit_card") return "Cartão de crédito";
+  if (m === "cash") return "Dinheiro";
+  if (m === "transfer") return "Transferência";
+  return escape(method);
+}
+
+function studentPaymentActions(p, status) {
+  const hasGatewayAction = Boolean(p.invoice_url || p.boleto_url || p.pix_copy_paste);
+  if (status === "paid" || status === "cancelled") {
+    return `<button class="mini-btn mini-btn-ghost" onclick="openStudentPaymentDetails('${p.id}')">Ver detalhes</button>`;
+  }
+  const access = paymentAccessHTML(p);
+  return `${hasGatewayAction ? access : ""}<button class="mini-btn mini-btn-ghost" onclick="openStudentPaymentDetails('${p.id}')">${hasGatewayAction ? "Detalhes" : "Ver detalhes"}</button>`;
+}
+
+function studentFinanceSummaryCard(label, value, sub, tone = "") {
+  return `<div class="finance-summary-card ${tone}">
+    <div class="finance-summary-label">${label}</div>
+    <div class="finance-summary-value">${value}</div>
+    <div class="finance-summary-sub">${sub}</div>
+  </div>`;
+}
+
+function studentFinanceItem(p) {
+  const status = paymentEffectiveStatus(p);
+  const dueLabel = p.due_date ? fmtDateBR(p.due_date) : "Sem vencimento";
+  const paidLabel = p.paid_at ? fmtDateBR(String(p.paid_at).slice(0, 10)) : "";
+  return `<div class="finance-item ${status}">
+    <div class="finance-item-head">
+      <div style="min-width:0;flex:1">
+        <div class="finance-item-title">${paymentTitle(p)}</div>
+        <div class="finance-item-meta">
+          Vencimento: ${dueLabel}${paidLabel ? ` · Pago em ${paidLabel}` : ""}<br>
+          ${paymentMethodLabel(p.method || p.payment_method)}
+        </div>
+      </div>
+      ${paymentStatusBadge(status)}
+    </div>
+    <div class="finance-item-amount">${fmtMoney(p.amount || 0)}</div>
+    ${p.notes ? `<div class="finance-item-meta">${escape(p.notes)}</div>` : ""}
+    <div class="finance-actions">${studentPaymentActions(p, status)}</div>
+  </div>`;
+}
