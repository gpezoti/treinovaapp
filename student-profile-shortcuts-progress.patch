+const PROGRESS_PHOTO_BUCKET = "progress";
+
+function getProgressPhotoPath(photo) {
+  const direct = photo && (photo.storage_path || photo.path || photo.file_path || photo.object_path);
+  if (direct) return String(direct).replace(/^\/+/, "");
+  const raw = String((photo && photo.url) || "").trim();
+  if (!raw) return "";
+  if (!/^https?:\/\//i.test(raw) && !/^data:/i.test(raw) && !/^blob:/i.test(raw)) {
+    return raw.replace(/^\/+/, "");
+  }
+  try {
+    const parsed = new URL(raw, location.href);
+    const parts = parsed.pathname.split(`/storage/v1/object/public/${PROGRESS_PHOTO_BUCKET}/`);
+    if (parts[1]) return decodeURIComponent(parts[1]);
+    const signedParts = parsed.pathname.split(`/storage/v1/object/sign/${PROGRESS_PHOTO_BUCKET}/`);
+    if (signedParts[1]) return decodeURIComponent(signedParts[1]);
+  } catch (e) {}
+  return "";
+}
+
+async function resolveProgressPhotoUrl(photo) {
+  const raw = String((photo && photo.url) || "").trim();
+  if (/^(data|blob):/i.test(raw)) return raw;
+  const path = getProgressPhotoPath(photo);
+  if (path) {
+    try {
+      const { data, error } = await sb.storage.from(PROGRESS_PHOTO_BUCKET).createSignedUrl(path, 60 * 60);
+      if (!error && data && data.signedUrl) return data.signedUrl;
+    } catch (e) {}
+    try {
+      const { data } = sb.storage.from(PROGRESS_PHOTO_BUCKET).getPublicUrl(path);
+      if (data && data.publicUrl) return data.publicUrl;
+    } catch (e) {}
+  }
+  return raw;
+}
